{#
/**
 * @file
 * Theme override for the user registration form.
 */
#}
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-6">
      <div class="text-center mb-5">
        <img src="/themes/custom/forseti/images/logos/originals/forseti_connected.png" alt="Forseti" class="forseti-chat-icon mb-4">
        <h1 class="mb-3">Join Forseti</h1>
        <p class="lead">Create your account to access AI-powered safety insights and community features.</p>
      </div>
      
      <div class="card-forseti p-4">
        <form{{ attributes }}>
          {{ children }}
        </form>
      </div>
      
      <div class="text-center mt-4">
        <p class="text-muted">
          Already have an account? <a href="/user/login" class="link-cyan">Sign in</a>
        </p>
      </div>
    </div>
  </div>
</div>