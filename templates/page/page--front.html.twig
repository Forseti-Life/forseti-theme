{#
/**
 * @file
 * Forseti Community Home Page
 * Theme override for the front page - Community-focused landing page
 * Source: institutional_management module templates/page--front.html.twig
 */
#}

{{ attach_library('forseti/animated-header') }}

<div class="page-wrapper">
  {# Animated Header Section - Full Height Home Header #}
  <div id="large-header" class="large-header home-header">
    <canvas id="demo-canvas"></canvas>
    <h1 class="main-title">
      <span class="highlight">Forseti</span> <span class="thin">Life</span>
    </h1>
    <p class="main-subtitle">
      Free resume tailoring for job seekers (current service focus)
    </p>
    <div class="hero-cta">
      <a href="/jobhunter" class="btn btn-primary">Start Free Resume Tailoring</a>
      <a href="/user/register" class="btn btn-outline-light">Create Free Account</a>
      <a href="/how-it-works" class="btn btn-outline-light">How It Works</a>
    </div>
  </div>

  {# Navigation - Using Radix Navbar Component #}
  {% block page_navigation %}
    {% embed 'radix:navbar' with {
      navbar_container_type: null,
      navbar_expand: 'lg',
      navbar_theme: 'dark',
      navbar_utility_classes: [
        'forseti-navbar',
        'forseti-navbar-front',
      ],
    } %}
      {% block branding %}
        {% if page.navbar_branding %}
          {{ page.navbar_branding }}
        {% endif %}
      {% endblock %}

      {% block left %}
        {% if page.navbar_left %}
          <div class="me-auto">
            {{ page.navbar_left }}
          </div>
        {% endif %}
      {% endblock %}

      {% block right %}
        {% if page.navbar_right or not logged_in %}
          {{ attach_library('forseti/navbar_right') }}
          <div class="ms-auto region-navbar-right d-flex align-items-center gap-2">
            {% if page.navbar_right %}
              {{ page.navbar_right }}
            {% endif %}
            {% if not logged_in %}
              <a href="{{ path('user.login') }}" class="btn btn-outline-light btn-sm navbar-signin-button">Sign in</a>
            {% endif %}
          </div>
        {% endif %}
      {% endblock %}
    {% endembed %}
  {% endblock %}

  {# Main Content #}
  <main class="main-content">
    {% if page.header %}
      <div class="header-region">
        <div class="container">
          {{ page.header }}
        </div>
      </div>
    {% endif %}

    <div class="container py-5">
      {# Community Philosophy Section #}
      <section id="about-community" class="mb-5">
        <div class="row">
          <div class="col-lg-10 mx-auto">
            <h2 class="text-center mb-4">Our Community Philosophy</h2>
            <div class="lead text-center mb-4">
              <p>We are a tolerant, scientific, technology-embracing community that takes care of its own.</p>
            </div>
            <div class="row mt-5">
              <div class="col-md-4 text-center mb-4">
                <div class="philosophy-icon mb-3">
                  <i class="fas fa-brain fa-3x text-primary"></i>
                </div>
                <h4>Science & Technology</h4>
                <p>We embrace scientific methodology and cutting-edge technology to improve our lives and advance our capabilities.</p>
              </div>
              <div class="col-md-4 text-center mb-4">
                <div class="philosophy-icon mb-3">
                  <i class="fas fa-users fa-3x text-primary"></i>
                </div>
                <h4>Community Care</h4>
                <p>We believe in taking care of our own, building services and infrastructure that adds value to every member.</p>
              </div>
              <div class="col-md-4 text-center mb-4">
                <div class="philosophy-icon mb-3">
                  <i class="fas fa-balance-scale fa-3x text-primary"></i>
                </div>
                <h4>Tolerance & Equity</h4>
                <p>We maintain a tolerant environment focused on creating equity and value for all community members.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      {# What We Build Section #}
      <section id="services" class="mb-5 bg-light py-5">
        <div class="row">
          <div class="col-lg-10 mx-auto">
            <h2 class="text-center mb-4">What We Build</h2>
            <div class="lead text-center mb-4">
              <p>We build services and expand artificial intelligence for our community members by automating anything that can add value and equity to the community as a whole.</p>
            </div>
            <div class="row mt-4">
              <div class="col-md-6 mb-4">
                <div class="card h-100">
                  <div class="card-body">
                    <h5 class="card-title">
                      <i class="fas fa-robot text-primary me-2"></i>
                      AI-Powered Automation
                    </h5>
                    <p class="card-text">Leveraging artificial intelligence to automate processes and create efficiencies that benefit all members.</p>
                  </div>
                </div>
              </div>
              <div class="col-md-6 mb-4">
                <div class="card h-100">
                  <div class="card-body">
                    <h5 class="card-title">
                      <i class="fas fa-tools text-primary me-2"></i>
                      Member Services
                    </h5>
                    <p class="card-text">Custom services designed by the community, for the community, addressing real needs and creating tangible value.</p>
                  </div>
                </div>
              </div>
              <div class="col-md-6 mb-4">
                <div class="card h-100">
                  <div class="card-body">
                    <h5 class="card-title">
                      <i class="fas fa-chart-line text-primary me-2"></i>
                      Community Growth
                    </h5>
                    <p class="card-text">Building infrastructure and systems that scale with our community's evolving needs.</p>
                  </div>
                </div>
              </div>
              <div class="col-md-6 mb-4">
                <div class="card h-100">
                  <div class="card-body">
                    <h5 class="card-title">
                      <i class="fas fa-handshake text-primary me-2"></i>
                      Collaborative Innovation
                    </h5>
                    <p class="card-text">Members contribute ideas, skills, and resources to collectively build solutions.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {# Membership Section #}
      <section id="membership" class="mb-5">
        <div class="row">
          <div class="col-lg-8 mx-auto">
            <h2 class="text-center mb-4">Free Access for Job Seekers</h2>
            
            <div class="card mb-4">
              <div class="card-body">
                <h4 class="card-title">
                  <i class="fas fa-lock text-primary me-2"></i>
                  Current Service Focus
                </h4>
                <p class="card-text">Forseti is currently focused on a free resume tailoring service that helps job seekers adapt resumes to real job descriptions.</p>
              </div>
            </div>

            <div class="card mb-4">
              <div class="card-body">
                <h4 class="card-title">
                  <i class="fas fa-user-check text-primary me-2"></i>
                  Simple Signup
                </h4>
                <p class="card-text">Create a free account and start using Job Hunter tools to upload, tailor, and manage resumes for your job search.</p>
              </div>
            </div>

            <div class="card mb-4">
              <div class="card-body">
                <h4 class="card-title">
                  <i class="fas fa-star text-primary me-2"></i>
                  What You Get Right Now
                </h4>
                <p class="card-text mb-3">Today, Forseti provides a free practical workflow for job seekers:</p>
                <ul>
                  <li><strong>Resume Tailoring</strong> - Tailor your resume to specific job descriptions</li>
                  <li><strong>Job Hunter Workflow</strong> - Track and organize your job application process</li>
                </ul>
                <p class="card-text">This core service is free while we continue expanding additional offerings.</p>
              </div>
            </div>

            <div class="text-center mt-5">
              <a href="/user/register" class="btn btn-primary btn-lg">
                <i class="fas fa-user-plus me-2"></i>
                Create Free Account
              </a>
            </div>
          </div>
        </div>
      </section>

      {# Drupal Content Region #}
      <div class="row">
        <div class="col">
          {% if page.content %}
            {{ page.content }}
          {% endif %}
        </div>
      </div>
    </div>
  </main>

  {# Footer #}
  {% if page.footer %}
    {{ page.footer }}
  {% endif %}
</div>
