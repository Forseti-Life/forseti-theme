{#
/**
 * Header Navigation Template
 * 
 * DESIGN REFERENCE:
 * - docs/product/design/01-sitemap-navigation.md (Lines 313-340)
 * - docs/product/design/02-wireframes.md (Lines 658-692)
 * 
 * IMPLEMENTATION DETAILS:
 * - Global header for web platform
 * - Forseti logo/brand
 * - Primary navigation links
 * - User account dropdown
 * - Responsive: collapses to hamburger menu on mobile
 * 
 * ACCESSIBILITY:
 * - Semantic <nav> element
 * - ARIA labels for navigation
 * - Keyboard navigation support
 * - See docs/product/design/05-accessibility-checklist.md (Lines 212-270)
 */
#}

<header class="site-header" role="banner">
  <div class="header-container">
    {# Logo #}
    <div class="header-logo">
      <a href="/" aria-label="Forseti home">
        <img src="{{ logo }}" alt="Forseti logo" class="logo-image" />
        <span class="logo-text">Forseti</span>
      </a>
    </div>
    
    {# Primary Navigation #}
    <nav class="header-nav" role="navigation" aria-label="Main navigation">
      <ul class="nav-menu">
        <li class="nav-item">
          <a href="/safety-map" class="nav-link" aria-current="{{ is_current_path('/safety-map') ? 'page' : false }}">
            Safety Map
          </a>
        </li>
        <li class="nav-item">
          <a href="/about" class="nav-link" aria-current="{{ is_current_path('/about') ? 'page' : false }}">
            About
          </a>
        </li>
        <li class="nav-item">
          <a href="/how-it-works" class="nav-link" aria-current="{{ is_current_path('/how-it-works') ? 'page' : false }}">
            How It Works
          </a>
        </li>
      </ul>
    </nav>
    
    {# User Account #}
    <div class="header-account">
      {% if logged_in %}
        {# Logged in state #}
        <button 
          class="account-button" 
          aria-haspopup="true" 
          aria-expanded="false"
          aria-label="Account menu"
          id="account-menu-button"
        >
          <span class="icon-account" aria-hidden="true"></span>
          <span class="account-name">{{ user.name }}</span>
          <span class="icon-chevron-down" aria-hidden="true"></span>
        </button>
        
        {# Account Dropdown #}
        <div 
          class="account-dropdown" 
          role="menu" 
          aria-hidden="true"
          aria-labelledby="account-menu-button"
        >
          <a href="/account" role="menuitem" class="dropdown-item">
            <span class="icon-home" aria-hidden="true"></span>
            Dashboard
          </a>
          <a href="/account/settings" role="menuitem" class="dropdown-item">
            <span class="icon-settings" aria-hidden="true"></span>
            Settings
          </a>
          <hr class="dropdown-divider" role="separator" />
          <a href="/user/logout" role="menuitem" class="dropdown-item">
            <span class="icon-logout" aria-hidden="true"></span>
            Logout
          </a>
        </div>
      {% else %}
        {# Not logged in state #}
        <a href="/user/login" class="button-login">Login</a>
        <a href="/user/register" class="button-register">Sign Up</a>
      {% endif %}
    </div>
    
    {# Mobile Menu Toggle #}
    <button 
      class="mobile-menu-toggle" 
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <span class="icon-menu" aria-hidden="true"></span>
      <span class="sr-only">Menu</span>
    </button>
  </div>
  
  {# Mobile Navigation Drawer #}
  <div class="mobile-nav" id="mobile-nav" aria-hidden="true">
    <button class="mobile-nav-close" aria-label="Close navigation menu">
      <span class="icon-close" aria-hidden="true"></span>
    </button>
    
    <nav class="mobile-nav-content" role="navigation" aria-label="Mobile navigation">
      <ul class="mobile-nav-menu">
        <li class="mobile-nav-item">
          <a href="/safety-map" class="mobile-nav-link">Safety Map</a>
        </li>
        <li class="mobile-nav-item">
          <a href="/about" class="mobile-nav-link">About</a>
        </li>
        <li class="mobile-nav-item">
          <a href="/how-it-works" class="mobile-nav-link">How It Works</a>
        </li>
        
        {% if logged_in %}
          <li class="mobile-nav-divider" role="separator"></li>
          <li class="mobile-nav-item">
            <a href="/account" class="mobile-nav-link">Dashboard</a>
          </li>
          <li class="mobile-nav-item">
            <a href="/account/settings" class="mobile-nav-link">Settings</a>
          </li>
          <li class="mobile-nav-item">
            <a href="/user/logout" class="mobile-nav-link">Logout</a>
          </li>
        {% else %}
          <li class="mobile-nav-divider" role="separator"></li>
          <li class="mobile-nav-item">
            <a href="/user/login" class="mobile-nav-link">Login</a>
          </li>
          <li class="mobile-nav-item">
            <a href="/user/register" class="mobile-nav-link">Sign Up</a>
          </li>
        {% endif %}
      </ul>
    </nav>
  </div>
</header>

{# 
CSS Implementation (in theme stylesheet):

.site-header {
  background-color: var(--color-card);
  border-bottom: 1px solid var(--color-border);
  position: sticky;
  top: 0;
  z-index: 1000;
}

.header-container {
  max-width: 1440px;
  margin: 0 auto;
  padding: 1rem 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* Logo */
.header-logo a {
  display: flex;
  align-items: center;
  text-decoration: none;
  color: var(--color-text);
}

.logo-image {
  height: 40px;
  width: auto;
}

.logo-text {
  margin-left: 0.75rem;
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--color-primary);
}

/* Desktop Navigation */
.header-nav {
  display: none; /* Hidden on mobile */
}

@media (min-width: 768px) {
  .header-nav {
    display: block;
    flex: 1;
    margin: 0 2rem;
  }
}

.nav-menu {
  display: flex;
  gap: 2rem;
  list-style: none;
  margin: 0;
  padding: 0;
}

.nav-link {
  color: var(--color-text-secondary);
  text-decoration: none;
  font-weight: 500;
  transition: color 0.2s;
}

.nav-link:hover,
.nav-link:focus {
  color: var(--color-primary);
}

.nav-link[aria-current="page"] {
  color: var(--color-primary);
  border-bottom: 2px solid var(--color-primary);
}

/* Account Menu */
.header-account {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.account-button {
  display: none; /* Hidden on mobile */
  background: none;
  border: none;
  color: var(--color-text);
  cursor: pointer;
  padding: 0.5rem 1rem;
  border-radius: 0.5rem;
  transition: background-color 0.2s;
}

@media (min-width: 768px) {
  .account-button {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
}

.account-button:hover,
.account-button:focus {
  background-color: var(--color-surface);
}

/* Mobile Menu Toggle */
.mobile-menu-toggle {
  display: block;
  background: none;
  border: none;
  color: var(--color-text);
  cursor: pointer;
  padding: 0.5rem;
  /* Minimum 44x44pt touch target */
  min-width: 44px;
  min-height: 44px;
}

@media (min-width: 768px) {
  .mobile-menu-toggle {
    display: none;
  }
}

/* Mobile Navigation Drawer */
.mobile-nav {
  position: fixed;
  top: 0;
  right: -100%;
  width: 80%;
  max-width: 320px;
  height: 100vh;
  background-color: var(--color-card);
  box-shadow: -4px 0 8px rgba(0, 0, 0, 0.2);
  transition: right 0.3s;
  z-index: 1001;
}

.mobile-nav[aria-hidden="false"] {
  right: 0;
}

/* Screen reader only text */
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border-width: 0;
}

/**
 * Responsive Behavior:
 * - Mobile (< 768px): Hamburger menu, bottom navigation shown
 * - Tablet (768px - 1023px): Header navigation visible
 * - Desktop (1024px+): Full header with dropdown
 * 
 * Reference: docs/product/design/04-mobile-first-approach.md (Lines 63-87)
 */
#}
