{#
/**
 * @file
 * Theme override for a profile entity (job seeker profile type).
 *
 * Available variables:
 * - profile: A profile entity.
 * - attributes: HTML attributes for the containing element.
 * - content: Profile content.
 * - label: The name of the profile type.
 * - url: The URL of this profile.
 * - view_mode: View mode; e.g., 'full', 'teaser', etc.
 *
 * @see template_preprocess_profile()
 */
#}

<div{{ attributes.addClass('profile-wrapper') }}>
  {% if content %}
    {# Professional card layout matching the user profile #}
    <div class="user-profile-card">
      <div class="row">
        {# Left column - Profile Image #}
        <div class="col-md-3">
          <div class="user-avatar-section">
            {% if content.user_picture %}
              {{ content.user_picture }}
            {% else %}
              <div class="default-avatar">
                <i class="fas fa-user-circle" aria-hidden="true"></i>
              </div>
            {% endif %}
          </div>
        </div>
        
        {# Right column - Profile Information #}
        <div class="col-md-9">
          <div class="user-info-section">
            {# Profile Title/Name #}
            <div class="user-name-section">
              <h1 class="user-name">
                {% if profile.getOwner().getDisplayName() %}
                  {{ profile.getOwner().getDisplayName() }}
                {% else %}
                  Job Seeker Profile
                {% endif %}
              </h1>
              <div class="user-role">Job Seeker</div>
            </div>
            
            {# Profile Fields #}
            <div class="user-details">
              {% for field_name, field_item in content %}
                {% if field_name|first != '#' and field_name != 'user_picture' %}
                  <div class="field-item">
                    <div class="field-wrapper">
                      {{ field_item }}
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</div>