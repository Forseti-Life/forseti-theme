{#
/**
 * @file
 * Theme override to display the main menu with Bootstrap 5 dropdowns.
 */
#}
{% import _self as menus %}

{#
  We call a macro which calls itself to render the full tree.
  @see https://twig.symfony.com/doc/3.x/tags/macro.html
#}
{% macro menu_links(items, attributes, menu_level) %}
  {% import _self as menus %}
  {% if items %}
    {% if menu_level == 0 %}
      <ul{{ attributes.addClass('nav', 'navbar-nav') }}>
    {% else %}
      <ul class="dropdown-menu">
    {% endif %}
    {% for item in items %}
      {# Skip Home and Privacy links #}
      {% if item.title not in ['Home', 'Privacy'] %}
        {% set item_classes = [
          menu_level == 0 ? 'nav-item',
          item.below ? 'dropdown',
        ] %}
      
        {% if item.below %}
          {# Item has children - render as dropdown #}
          <li{{ item.attributes.addClass(item_classes) }}>
            <a href="{{ item.url }}" 
               class="{{ menu_level == 0 ? 'nav-link dropdown-toggle' : 'dropdown-item dropdown-toggle' }}" 
               id="dropdown-{{ item.title|clean_id }}" 
               role="button"
               aria-expanded="false">
              {{ item.title }}
            </a>
            {{ menus.menu_links(item.below, attributes.removeClass('nav', 'navbar-nav'), menu_level + 1) }}
          </li>
        {% else %}
          {# Regular link without children #}
          <li{{ item.attributes.addClass(item_classes) }}>
            <a href="{{ item.url }}" class="{{ menu_level == 0 ? 'nav-link' : 'dropdown-item' }}">{{ item.title }}</a>
          </li>
        {% endif %}
      {% endif %}
    {% endfor %}
    </ul>
  {% endif %}
{% endmacro %}

{{ menus.menu_links(items, attributes, 0) }}
