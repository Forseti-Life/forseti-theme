<?php

/**
 * @file
 * Theme and preprocess functions for users.
 */

/**
 * Implements hook_preprocess_user().
 */
function forseti_preprocess_user(&$variables) {
  /** @var \Drupal\user\Entity\User $user */
  $user = $variables['user'];
  
  // Add user ID
  $variables['user_id'] = $user->id();
  
  // Get the current user to check permissions
  $current_user = \Drupal::currentUser();
  $variables['can_edit'] = $current_user->id() == $user->id() || $current_user->hasPermission('administer users');
  
  // Format skills as an array
  if (!empty($variables['content']['field_skills'])) {
    $skills_field = $user->get('field_skills');
    if (!$skills_field->isEmpty()) {
      $skills = [];
      foreach ($skills_field as $item) {
        if (!empty($item->value)) {
          $skills[] = $item->value;
        }
      }
      $variables['skills_list'] = $skills;
    }
  }
  
  // Format certifications as an array
  if (!empty($variables['content']['field_certifications'])) {
    $certs_field = $user->get('field_certifications');
    if (!$certs_field->isEmpty()) {
      $certifications = [];
      foreach ($certs_field as $item) {
        if (!empty($item->value)) {
          $certifications[] = $item->value;
        }
      }
      $variables['certifications_list'] = $certifications;
    }
  }
  
  // Format preferred roles as an array
  if (!empty($variables['content']['field_preferred_roles'])) {
    $roles_field = $user->get('field_preferred_roles');
    if (!$roles_field->isEmpty()) {
      $roles = [];
      foreach ($roles_field as $item) {
        if (!empty($item->value)) {
          $roles[] = $item->value;
        }
      }
      $variables['preferred_roles_list'] = $roles;
    }
  }
  
  // Process salary expectation
  if (!empty($variables['content']['field_salary_expectation'])) {
    $salary_field = $user->get('field_salary_expectation');
    if (!$salary_field->isEmpty()) {
      $salary = $salary_field->value;
      $variables['formatted_salary'] = '$' . number_format($salary);
    }
  }
  
  // Process years of experience
  if (!empty($variables['content']['field_years_experience'])) {
    $exp_field = $user->get('field_years_experience');
    if (!$exp_field->isEmpty()) {
      $years = $exp_field->value;
      $variables['experience_text'] = $years . ' year' . ($years != 1 ? 's' : '') . ' of experience';
    }
  }
  
  // Add formatted join date
  $variables['member_since'] = \Drupal::service('date.formatter')->format($user->getCreatedTime(), 'custom', 'F j, Y');
  
  // Add social media links if they exist
  $social_links = [];
  if (!empty($variables['content']['field_linkedin_url']) && !$user->get('field_linkedin_url')->isEmpty()) {
    $social_links['linkedin'] = $user->get('field_linkedin_url')->uri;
  }
  if (!empty($variables['content']['field_github_url']) && !$user->get('field_github_url')->isEmpty()) {
    $social_links['github'] = $user->get('field_github_url')->uri;
  }
  if (!empty($variables['content']['field_portfolio_url']) && !$user->get('field_portfolio_url')->isEmpty()) {
    $social_links['portfolio'] = $user->get('field_portfolio_url')->uri;
  }
  $variables['social_links'] = $social_links;
}
