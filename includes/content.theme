<?php

/**
 * @file
 * Theme and preprocess functions for nodes.
 */

/**
 * Implements hook_preprocess_node().
 * 
 * Hide authoring information by default for all content types.
 */
function forseti_preprocess_node(&$variables) {
  // Hide authoring information (submitted by, date) for all nodes
  $variables['display_submitted'] = FALSE;
  
  // Also ensure date and author are not displayed
  unset($variables['metadata']);
  $variables['date'] = '';
  $variables['author_name'] = '';
  $variables['author_picture'] = '';
}
